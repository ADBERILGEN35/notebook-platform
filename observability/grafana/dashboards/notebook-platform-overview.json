{
  "uid": "notebook-platform-overview",
  "title": "Notebook Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["notebook-platform", "phase-17"],
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": "label_values(http_server_requests_seconds_count, application)",
        "refresh": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$application\"}[5m]))", "legendFormat": "{{application}}"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx rate",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$application\",status=~\"5..\"}[5m]))", "legendFormat": "{{application}}"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, application) (rate(http_server_requests_seconds_bucket{application=~\"$application\",uri!~\"/actuator.*\"}[5m])))", "legendFormat": "{{application}}"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p99",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.99, sum by (le, application) (rate(http_server_requests_seconds_bucket{application=~\"$application\",uri!~\"/actuator.*\"}[5m])))", "legendFormat": "{{application}}"}]
    },
    {
      "type": "stat",
      "title": "Service availability",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 6},
      "targets": [{"expr": "avg by (application) (up{application=~\"$application\"})", "legendFormat": "{{application}}"}]
    },
    {
      "type": "timeseries",
      "title": "Gateway 429 rate",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 6},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"api-gateway\",status=\"429\"}[5m]))", "legendFormat": "429/s"}]
    },
    {
      "type": "timeseries",
      "title": "Error code cardinality",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 6},
      "targets": [{"expr": "count(count by (errorCode, application) (http_server_requests_seconds_count{application=~\"$application\",status=~\"4..|5..\"}))", "legendFormat": "error codes"}]
    }
  ]
}
