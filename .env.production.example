# Production template. Replace placeholders through your secret manager, CI/CD
# secret store, or Docker secrets. Do not commit a populated .env.production.
SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:postgresql://postgres.example.internal:5432/notebook_platform
DB_USER=
DB_PASSWORD=
DB_RUNTIME_URL=jdbc:postgresql://postgres.example.internal:5432/notebook_platform
DB_RUNTIME_USER=notebook_runtime
DB_RUNTIME_PASSWORD=<required-runtime-password-from-secret-manager>
DB_MIGRATION_USER=notebook_migrator
DB_MIGRATION_PASSWORD=<required-migration-password-from-secret-manager>
SPRING_FLYWAY_USER=notebook_migrator
SPRING_FLYWAY_PASSWORD=<required-migration-password-from-secret-manager>

REDIS_HOST=redis.example.internal
REDIS_PORT=6379
REDIS_PASSWORD=<recommended-from-secret-manager>

JWT_ALLOW_EPHEMERAL_KEYS=false
JWT_KEYS_ACTIVE_KID=prod-key-1
JWT_KEYS_SIGNING_KEYS_0_KID=prod-key-1
JWT_KEYS_SIGNING_KEYS_0_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key_1
JWT_KEYS_SIGNING_KEYS_0_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key_1
JWT_KEYS_SIGNING_KEYS_1_KID=
JWT_KEYS_SIGNING_KEYS_1_PRIVATE_KEY_PATH=
JWT_KEYS_SIGNING_KEYS_1_PUBLIC_KEY_PATH=
JWT_PRIVATE_KEY=
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_PATH=
JWT_JWKS_URI=http://identity-service:8081/.well-known/jwks.json

INTERNAL_API_TOKEN_PRIMARY=<required-from-secret-manager>
INTERNAL_API_TOKEN_SECONDARY=
WORKSPACE_INTERNAL_API_TOKEN_PRIMARY=<required-same-current-token-as-workspace-primary>
WORKSPACE_INTERNAL_API_TOKEN_SECONDARY=

CORS_ALLOWED_ORIGINS=https://app.example.com
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.internal/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <otel-token-from-secret-manager>
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus
APP_RLS_ENABLED=false
APP_RLS_STRICT_WORKSPACE_HEADER=false
