# PostgreSQL (local example only)
DB_URL=jdbc:postgresql://localhost:5432/notebook_platform
DB_USER=notebook
DB_PASSWORD=notebook

# JWT (RS256) - optional in dev/test (service generates ephemeral keys if unset)
JWT_ALLOW_EPHEMERAL_KEYS=true
JWT_KEYS_ACTIVE_KID=primary
JWT_KEYS_SIGNING_KEYS_0_KID=
JWT_KEYS_SIGNING_KEYS_0_PRIVATE_KEY_PATH=
JWT_KEYS_SIGNING_KEYS_0_PUBLIC_KEY_PATH=
JWT_KEYS_SIGNING_KEYS_1_KID=
JWT_KEYS_SIGNING_KEYS_1_PRIVATE_KEY_PATH=
JWT_KEYS_SIGNING_KEYS_1_PUBLIC_KEY_PATH=
JWT_PRIVATE_KEY=
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_PATH=

# Token TTLs (seconds)
JWT_ACCESS_TOKEN_TTL=300
JWT_REFRESH_TOKEN_TTL=604800

# Argon2id params (tunable; test profile uses lower values)
ARGON2_SALT_LENGTH=16
ARGON2_HASH_LENGTH=32
ARGON2_PARALLELISM=1
ARGON2_MEMORY_IN_KB=65536
ARGON2_ITERATIONS=3

